{
	"layer": "top",
	"position": "top",
	"modules-left": [
		"custom/launcher",
		"custom/polycat",
		"hyprland/workspaces"
	],
	"modules-center": [
		"custom/music"
	],
	"modules-right": [
		"pulseaudio",
		"custom/ddcutil",
		"clock",
		"tray",
		"hyprland/language",
		"custom/lock",
		"custom/power"
	],
	"hyprland/workspaces": {
		"on-click": "activate",
		"on-scroll-up": "hyprctl dispatch workspace e-1",
		"on-scroll-down": "hyprctl dispatch workspace e+1",
		"format": "{icon}",
		"all-outputs": true,
		"format-icons": {
			"1": "п„ ",
			"2": "у°–џ",
			"3": "пЃµ",
			"4": "у°Ћ‰",
			"5": "у°›і",
			"default": "п„‘"
		}
	},
	"tray": {
		"icon-size": 21,
		"spacing": 10
	},
	"custom/music": {
		"format": "пЂЃ  {}",
		"escape": true,
		"interval": 5,
		"tooltip": false,
		"exec": "playerctl metadata --format='{{ title }}'",
		"on-click": "playerctl play-pause",
		"max-length": 50
	},
	"clock": {
		"timezone": "Asia/Hong Kong",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "пЃі {:%d/%m/%Y}",
		"format": "пЂ— {:%H:%M}"
	},
	"custom/ddcutil": {
		"format": "{percentage}% {icon}",
		"interval": 1,
		"on-scroll-up": "ddcutil setvcp --bus 10 10 $(expr `ddcutil getvcp --bus 10 10 | grep -oP '[0-9]+' | tail -2 | head -1` + 10)",
		"on-scroll-down": "ddcutil setvcp --bus 10 10 $(expr `ddcutil getvcp --bus 10 10 | grep -oP '[0-9]+' | tail -2 | head -1` - 10)",
		"on-click": "ddcutil setvcp 10 50",
		"exec": "~/.config/waybar/waybar-ddcutil.py",
		"format-icons": [
			"оЋЌ",
			"оЏ“",
			"оЏ‘",
			"оЏЏ",
			"оЏЋ",
			"оЏЌ",
			"оЏЉ",
			"оЏ€",
			"оЋ›"
		],
		"return-type": "json"
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon}",
		"format-charging": "у°‚„",
		"format-plugged": "п‡¦",
		"format-alt": "{icon}",
		"format-icons": [
			"п‰„",
			"п‰ѓ",
			"п‰‚",
			"п‰Ѓ",
			"п‰Ђ"
		]
	},
	"pulseaudio": {
		// "scroll-step": 1, // %, can be a float
		"format": "{icon} {volume}%",
		"format-muted": "п‘¦",
		"format-icons": {
			"default": [
				"пЂ¦",
				"пЂ§",
				"пЂЁ "
			]
		},
		"on-click": "pavucontrol"
	},
	"custom/lock": {
		"tooltip": false,
		"on-click": "hyprlock &",
		"format": "пЂЈ"
	},
	"custom/power": {
		"tooltip": false,
		"on-click": "wlogout &",
		"format": "вЏ»"
	},
	"hyprland/language": {
		"format": "п„њ {}",
		"format-en": "en",
		"format-fa": "fa",
		"interval": 1,
		"keyboard-name": "gaming-keyboard",
		"on-click": "hyprctl switchxkblayout gaming-keyboard next"
	},
	"custom/launcher":{
		"format": "пЊѓ",
		"on-click": "fuzzel",
		"on-click-right": "fuzzel"
	},
	"custom/polycat":{
		"exec": "polycat",
		"return-type": "json",
		"format": "{text}",
		"tooltip": false,
		"restart-interval": 5
	}
}
