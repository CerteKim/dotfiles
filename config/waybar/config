{
	"layer": "top",
	"position": "top",
	"modules-left": [
		"custom/launcher",
		"custom/polycat",
		"hyprland/workspaces"
	],
	"modules-center": [
		"custom/music"
	],
	"modules-right": [
	    "group/status",
		"tray",
		"custom/power"
	],
	"group/status": {
		"orientation": "horizontal",
	    "modules": [
			"pulseaudio",
			"custom/ddcutil",
			"clock"
		]
	},
	"hyprland/workspaces": {
		"on-click": "activate",
		"on-scroll-up": "hyprctl dispatch workspace e-1",
		"on-scroll-down": "hyprctl dispatch workspace e+1",
		"format": "{icon}",
		"all-outputs": true,
		"format-icons": {
			"1": "ΎΕι",
			"2": "≤░Ψθ",
			"3": "ΎΒ╡",
			"4": "≤░ΟΚ",
			"5": "≤░δ│",
			"default": "ΎΕΣ"
		}
	},
	"tray": {
		"icon-size": 21,
		"spacing": 10
	},
	"custom/music": {
		"format": "ΎΑΒ  {}",
		"escape": true,
		"interval": 5,
		"tooltip": false,
		"exec": "playerctl metadata --format='{{ title }}'",
		"on-click": "playerctl play-pause",
		"max-length": 50
	},
	"clock": {
		"timezone": "Asia/Hong Kong",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "ΎΒ│ {:%d/%m/%Y}",
		"format": "ΎΑΩ {:%H:%M}"
	},
	"custom/ddcutil": {
		"format": "{percentage}% {icon}",
		"interval": 1,
		"on-scroll-up": "ddcutil setvcp --bus 10 10 $(expr `ddcutil getvcp --bus 10 10 | grep -oP '[0-9]+' | tail -2 | head -1` + 10)",
		"on-scroll-down": "ddcutil setvcp --bus 10 10 $(expr `ddcutil getvcp --bus 10 10 | grep -oP '[0-9]+' | tail -2 | head -1` - 10)",
		"on-click": "ddcutil setvcp 10 50",
		"exec": "~/.config/waybar/waybar-ddcutil.py",
		"format-icons": [
			"ΌΟΞ",
			"ΌΠΥ",
			"ΌΠΣ",
			"ΌΠΠ",
			"ΌΠΟ",
			"ΌΠΞ",
			"ΌΠΛ",
			"ΌΠΙ",
			"ΌΟδ"
		],
		"return-type": "json"
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon}",
		"format-charging": "≤░ΓΕ",
		"format-plugged": "ΎΘο",
		"format-alt": "{icon}",
		"format-icons": [
			"ΎΚΕ",
			"ΎΚΔ",
			"ΎΚΓ",
			"ΎΚΒ",
			"ΎΚΑ"
		]
	},
	"pulseaudio": {
		// "scroll-step": 1, // %, can be a float
		"format": "{icon} {volume}%",
		"format-muted": "ΎΣο",
		"format-icons": {
			"default": [
				"ΎΑο",
				"ΎΑπ",
				"ΎΑρ "
			]
		},
		"on-click": "pavucontrol"
	},
	"custom/lock": {
		"tooltip": false,
		"on-click": "hyprlock &",
		"format": "ΎΑμ"
	},
	"custom/power": {
		"tooltip": false,
		"on-click": "wlogout &",
		"format": "έΠ╗"
	},
	"hyprland/language": {
		"format": "ΎΕε {}",
		"format-en": "en",
		"format-fa": "fa",
		"interval": 1,
		"keyboard-name": "gaming-keyboard",
		"on-click": "hyprctl switchxkblayout gaming-keyboard next"
	},
	"custom/launcher":{
		"format": "ΎΝΔ",
		"on-click": "fuzzel",
		"on-click-right": "fuzzel"
	},
	"custom/polycat":{
		"exec": "polycat",
		"return-type": "json",
		"format": "{text}",
		"tooltip": false,
		"restart-interval": 5
	}
}
